{
    "name": "@page-mcp/chat",
    "version": "2.0.0",
    "description": "Embeddable AI Chat Widget with OpenAI-compatible API + Page MCP integration",
    "license": "MIT",
    "keywords": [
        "mcp",
        "page-mcp",
        "ai",
        "chat",
        "widget",
        "openai",
        "llm"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@page-mcp/core": "workspace:^",
        "dompurify": "^3.2.5",
        "marked": "^15.0.7"
    },
    "devDependencies": {
        "tsup": "^8.0.0",
        "typescript": "^5.4.0"
    }
}
