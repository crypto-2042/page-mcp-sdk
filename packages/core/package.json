{
    "name": "@page-mcp/core",
    "version": "1.1.0",
    "description": "Core SDK for Page MCP — expose web page capabilities to AI",
    "license": "MIT",
    "keywords": [
        "mcp",
        "page-mcp",
        "ai",
        "llm",
        "tools",
        "web-sdk",
        "webmcp"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "test": "pnpm exec vitest run",
        "test:watch": "pnpm exec vitest"
    },
    "devDependencies": {
        "tsup": "^8.0.0",
        "typescript": "^5.4.0",
        "vitest": "^2.1.9"
    }
}
