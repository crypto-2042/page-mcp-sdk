{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "installCommand": "pnpm install",
    "buildCommand": "pnpm run build",
    "outputDirectory": "public",
    "cleanUrls": true,
    "trailingSlash": false,
    "redirects": [
        {
            "source": "/",
            "destination": "/demo",
            "permanent": false
        }
    ],
    "headers": [
        {
            "source": "/packages/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        },
        {
            "source": "/demo/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        }
    ]
}
